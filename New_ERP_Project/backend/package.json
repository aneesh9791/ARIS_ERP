{
  "name": "new-erp-backend",
  "version": "1.0.0",
  "description": "Modern ERP system backend for Kerala Diagnostic Centers",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate": "node src/migrations/migrate.js",
    "seed": "node src/migrations/seed.js",
    "billing:migrate": "node migrate-billing.js migrate",
    "billing:validate": "node migrate-billing.js validate",
    "billing:backup": "node migrate-billing.js backup",
    "billing:rollback": "node migrate-billing.js rollback",
    "billing:report": "node migrate-billing.js report",
    "billing:test": "jest tests/billing.test.js",
    "billing:test:watch": "jest tests/billing.test.js --watch"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.6.2",
    "pg": "^8.11.3",
    "puppeteer": "^21.6.1",
    "redis": "^4.6.12",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.2",
    "joi": "^17.11.0",
    "nodemailer": "^6.9.7"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.10.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/express-session": "^1.17.10",
    "@types/cookie-parser": "^1.4.7",
    "@types/multer": "^1.4.11",
    "@types/compression": "^1.7.5",
    "@types/joi": "^17.2.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "typescript": "^5.3.2",
    "ts-node": "^10.9.1",
    "eslint": "^8.54.0",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "prettier": "^3.1.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "@types/jest": "^29.5.8",
    "ts-jest": "^29.1.1"
  },
  "keywords": ["erp", "business", "management", "nodejs", "kerala", "diagnostic"],
  "author": "ARIS ERP Team",
  "license": "MIT"
}
