# Development Environment Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aris_erp
DB_USER=postgres
DB_PASSWORD=password
DB_SSL=false
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Session Configuration
SESSION_SECRET=your-super-secret-session-key-change-in-production
SESSION_RESAVE=false
SESSION_SAVE_UNINITIALIZED=false
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_MAX_AGE=86400000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Local System API Integration
LOCAL_SYSTEM_API_ENDPOINT=http://localhost:8080/api/patient-demographics
LOCAL_SYSTEM_API_TOKEN=your_bearer_token_here
LOCAL_SYSTEM_API_KEY=your_api_key_here
API_REQUEST_TIMEOUT=15000
API_RETRY_ATTEMPTS=3
ENABLE_REQUEST_SIGNING=true
LOCAL_SYSTEM_CLIENT_ID=aris-erp
ENABLE_DEMOGRAPHICS_SYNC=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Configuration
UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@aris-erp.com

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# Puppeteer Configuration
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT=30000

# API Documentation
API_DOCS_ENABLED=true
API_DOCS_PATH=/api-docs

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/api/health

# Monitoring
MONITORING_ENABLED=false
METRICS_ENABLED=false

# Security
BCRYPT_ROUNDS=12
CSRF_SECRET=your-csrf-secret-key-change-in-production
HELMET_ENABLED=true

# Cache Configuration
CACHE_TTL=300
CACHE_MAX_SIZE=100

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# Date Format
DATE_FORMAT=YYYY-MM-DD
TIME_FORMAT=HH:mm:ss
DATETIME_FORMAT=YYYY-MM-DD HH:mm:ss

# Currency
CURRENCY=INR
CURRENCY_SYMBOL=₹

# Timezone
TIMEZONE=Asia/Kolkata

# Kerala Specific
GST_ENABLED=true
GST_RATE=18
PAN_REQUIRED=true
TDS_RATE=10

# Feature Flags
FEATURE_DASHBOARD_WIDGETS=true
FEATURE_REPORTS_EXPORT=true
FEATURE_BULK_OPERATIONS=true
FEATURE_REAL_TIME_UPDATES=false
FEATURE_MULTI_LANGUAGE=false
FEATURE_SMS_NOTIFICATIONS=false

# Development
DEV_AUTO_RELOAD=true
DEV_DEBUG_SQL=false
DEV_MOCK_EXTERNAL_APIS=false
